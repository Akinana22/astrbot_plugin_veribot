{
  "db_type": {
    "description": "数据库类型",
    "type": "string",
    "default": "postgresql",
    "options": ["postgresql", "mysql", "mariadb", "sqlite"]
  },
  "db_host": {
    "description": "数据库主机地址",
    "type": "string",
    "default": "localhost"
  },
  "db_port": {
    "description": "数据库端口",
    "type": "int",
    "default": 0
  },
  "db_name": {
    "description": "数据库名称",
    "type": "string",
    "default": ""
  },
  "db_user": {
    "description": "数据库用户名",
    "type": "string",
    "default": ""
  },
  "db_password": {
    "description": "数据库密码",
    "type": "string",
    "default": ""
  },
  "platform_table": {
    "description": "平台字段所在表",
    "type": "string",
    "default": "platform_bindings"
  },
  "platform_column": {
    "description": "平台字段列名",
    "type": "string",
    "default": "platform"
  },
  "qq_uid_table": {
    "description": "QQ UID 所在表",
    "type": "string",
    "default": "platform_bindings"
  },
  "qq_uid_column": {
    "description": "QQ UID 列名",
    "type": "string",
    "default": "platform_user_id"
  },
  "qq_code_table": {
    "description": "QQ 注册邀请码所在表",
    "type": "string",
    "default": "platform_bindings"
  },
  "qq_code_column": {
    "description": "QQ 注册邀请码列名",
    "type": "string",
    "default": "register_code_hash"
  },
  "discord_uid_table": {
    "description": "Discord UID 所在表",
    "type": "string",
    "default": "platform_bindings"
  },
  "discord_uid_column": {
    "description": "Discord UID 列名",
    "type": "string",
    "default": "platform_user_id"
  },
  "discord_code_table": {
    "description": "Discord 注册邀请码所在表",
    "type": "string",
    "default": "platform_bindings"
  },
  "discord_code_column": {
    "description": "Discord 注册邀请码列名",
    "type": "string",
    "default": "register_code_hash"
  },
  "is_used_table": {
    "description": "状态字段所在表",
    "type": "string",
    "default": "platform_bindings"
  },
  "is_used_column": {
    "description": "状态字段列名",
    "type": "string",
    "default": "is_used"
  },
  "auxiliary_password": {
    "description": "辅助密码（手动模式）",
    "type": "text",
    "hint": "关闭自动刷新时使用，每行一个密码，随机选取其中一个搭配用户ID生成注册邀请码"
  },
  "auto_refresh": {
    "description": "启用辅助密码自动刷新",
    "type": "bool",
    "default": false
  },
  "refresh_interval": {
    "description": "密码刷新间隔（分钟）",
    "type": "int",
    "default": 5,
    "hint": "取值范围 5-30 分钟"
  },
  "password_count": {
    "description": "每轮生成的密码数量",
    "type": "int",
    "default": 6,
    "hint": "取值范围 1-10"
  }
}
